    {
      "type": "paragraph",
      "html": "<strong>Posts exist on “posts” folder.</strong>"
    },
    {
      "type": "heading",
      "level": 2,
      "text": "Find the text of the given tag using BeautifulSoup"
    },
    {
      "type": "code",
      "lang": "text",
      "code": "# Importing BeautifulSoup class from the bs4 module from bs4 import BeautifulSoup   # Opening the html file HTMLFile = open(\"1.html\", \"r\") # Reading the file index = HTMLFile.read() # Creating a BeautifulSoup object and specifying the parser Parse = BeautifulSoup(index, 'lxml') print(Parse.title.string)print(Parse.body) "
    },
    {
      "type": "heading",
      "level": 2,
      "text": "Get content of Medium blog"
    },
    {
      "type": "paragraph",
      "html": "The class might be change in future it depend on medium policy."
    },
    {
      "type": "code",
      "lang": "text",
      "code": "text_element = Parse.find(class_='section-inner sectionLayout--insetColumn')text = text_element.get_text(strip=True)text = text.replace(u'\\xa0', u' ')text = (text.encode('ascii', 'ignore')).decode(\"utf-8\")"
    },
    {
      "type": "heading",
      "level": 2,
      "text": "Get Link of post"
    },
    {
      "type": "code",
      "lang": "text",
      "code": "link_element = Parse.find(class_='p-canonical')link = link_element.get('href')"
    },
    {
      "type": "heading",
      "level": 2,
      "text": "Get first image of post"
    },
    {
      "type": "code",
      "lang": "text",
      "code": "images = Parse.findAll('img')picture = images[0].get('src')"
    },
